# Use .env.local to change these variables
# DO NOT EDIT THIS FILE WITH SENSITIVE DATA

### Models ###
# Cloudflare Gateway base URL
OPENAI_BASE_URL=https://gateway.ai.cloudflare.com/v1/b73b80fa62deef032d3c08248cf2f30b/my-ai-token/compat

# Your Cloudflare API token
OPENAI_API_KEY=5d6918c77aee06e9f89890b9cdf6bc75

# Use user token for inference (true/false)
USE_USER_TOKEN=false

# Automatic login
AUTOMATIC_LOGIN=false

### MongoDB ###
# (Leave empty if not needed)
MONGODB_URL=
MONGODB_DB_NAME=chat-ui
MONGODB_DIRECT_CONNECTION=false

## Public app configuration ##
PUBLIC_APP_NAME=Cloudflare AI Chat
PUBLIC_APP_ASSETS=chatui
PUBLIC_APP_DESCRIPTION="A chat interface powered by Cloudflare Workers AI Gateway."
PUBLIC_ORIGIN=
PUBLIC_SHARE_PREFIX=
PUBLIC_GOOGLE_ANALYTICS_ID=
PUBLIC_PLAUSIBLE_SCRIPT_URL=
PUBLIC_APPLE_APP_ID=
PUBLIC_CAVEAT="Generated content may be inaccurate or false."

### Authentication (if needed later) ###
OPENID_CLIENT_ID=""
OPENID_CLIENT_SECRET=
OPENID_SCOPES="openid profile"

### Local Storage ###
MONGO_STORAGE_PATH=

## Models overrides (use dynamic route)
MODELS=

## Task model
TASK_MODEL=

### Admin stuff ###
ADMIN_CLI_LOGIN=true
ADMIN_TOKEN=

### Feature Flags ###
LLM_SUMMARIZATION=true
ALLOW_IFRAME=true

### Rate limits ###
USAGE_LIMITS={}

### Metrics ###
METRICS_ENABLED=false
METRICS_PORT=5565
LOG_LEVEL=info

### Docker build variables ###
APP_BASE=""
BODY_SIZE_LIMIT=15728640
PUBLIC_COMMIT_SHA=

### Other settings ###
ENABLE_CONFIG_MANAGER=true
